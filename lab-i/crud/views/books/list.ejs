<%- include('../partials/header', { title: 'Books List' }) %>

<section class="page-heading">
  <div>
    <h1>Books List</h1>
    <p>Custom Book model ported from the PHP CRUD application.</p>
  </div>
  <a class="button primary" href="/books/create">Create</a>
</section>

<table class="data-table">
  <thead>
    <tr>
      <th>ID</th>
      <th>Title</th>
      <th>Author</th>
      <th>Year</th>
      <th>Genre</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% books.forEach((book) => { %>
      <tr>
        <td><%= book.id %></td>
        <td><%= book.title %></td>
        <td><%= book.author %></td>
        <td><%= book.published_year %></td>
        <td><%= book.genre %></td>
        <td class="actions">
          <a href="/books/<%= book.id %>">Details</a>
          <a href="/books/<%= book.id %>/edit">Edit</a>
          <form action="/books/<%= book.id %>/delete" method="post">
            <button type="submit">Delete</button>
          </form>
        </td>
      </tr>
    <% }) %>
  </tbody>
</table>

<%- include('../partials/footer') %>
