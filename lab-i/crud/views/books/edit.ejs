<%- include('../partials/header', { title: 'Edit Book' }) %>

<section class="form-card">
  <h1>Edit Book</h1>

  <form method="post">
    <label>
      Title
      <input type="text" name="title" value="<%= book.title %>" required>
    </label>

    <label>
      Author
      <input type="text" name="author" value="<%= book.author %>" required>
    </label>

    <label>
      Published year
      <input type="number" name="publishedYear" value="<%= book.published_year %>" required>
    </label>

    <label>
      Genre
      <input type="text" name="genre" value="<%= book.genre %>" required>
    </label>

    <div class="button-row">
      <button class="button primary" type="submit">Update</button>
      <a class="button" href="/books">Back to list</a>
    </div>
  </form>
</section>

<%- include('../partials/footer') %>
