{% extends 'base.html.twig' %}

{% block title %}Post index{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1>Post index</h1>
        <a href="{{ path('app_post_new') }}" class="btn btn-primary">Create new</a>
    </div>

    <div class="table-responsive">
        <table class="table table-striped table-bordered align-middle">
            <thead class="table-dark">
            <tr>
                <th>Id</th>
                <th>Subject</th>
                <th>Description</th>
                <th>Actions</th>
            </tr>
            </thead>
            <tbody>
            {% for post in posts %}
                <tr>
                    <td>{{ post.id }}</td>
                    <td>{{ post.subject }}</td>
                    <td>{{ post.description }}</td>
                    <td>
                        <a href="{{ path('app_post_show', {'id': post.id}) }}" class="btn btn-sm btn-info">show</a>
                        <a href="{{ path('app_post_edit', {'id': post.id}) }}" class="btn btn-sm btn-warning">edit</a>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="4" class="text-center">no records found</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
{% endblock %}
