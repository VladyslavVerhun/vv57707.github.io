<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>{% block title %}PTW LAB H{% endblock %}</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    {% block stylesheets %}
    {% endblock %}
</head>

<body>
<nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4">
    <div class="container">
        <a class="navbar-brand" href="{{ path('app_post_index') }}">PTW LAB H</a>
        <div class="navbar-nav">
            <a class="nav-link" href="{{ path('app_post_index') }}">Posts</a>
            <a class="nav-link" href="{{ path('app_post_new') }}">Create new</a>
        </div>
    </div>
</nav>

<main class="container">
    {% block body %}{% endblock %}
</main>

<footer class="bg-light text-center py-3 mt-5 border-top">
    <small>Symfony CRUD application - Vladyslav Verhun</small>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

{% block javascripts %}
{% endblock %}
</body>
</html>
